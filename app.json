{
  "expo": {
    "name": "CareerPulse",
    "slug": "careerpulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "careerpulse",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2b2b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.acasapps.careerpulse"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0d2b2b"
      },
      "package": "com.acasapps.careerpulse"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
